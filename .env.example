# ---- Deployment (dev-vault-infra) ----
# Copy to .env and fill in real values. .env is not committed (see .gitignore).

# Base domain. Real DNS A-records must point to this host:
#   api.YOUR_DOMAIN  app.YOUR_DOMAIN  admin.YOUR_DOMAIN  ->  <server IP>
DOMAIN=YOUR_DOMAIN

# PostgreSQL password. The database is private (no public port); the backend
# reaches it over the internal network. Use a strong value in production.
POSTGRES_PASSWORD=change-me-in-prod
